{
  "name": "js-svg-client",
  "version": "2024.12.16",
  "type": "module",
  "help-build": "remove type: module to build webpack",
  "description": "Client Side SVG using JavaScript",
  "author": "Amit M. Manthanwar",
  "website": "http://54.205.5.132:3000",
  "homepage": "https://github.com/manthanwar/JS-SVG-Client",
  "license": "https://github.com/manthanwar/JS-SVG-Client/blob/main/LICENSE.md",
  "private": false,
  "scripts": {
    "build-node": "webpack --config webpack.config.js",
    "build": "webpack --config webpack.config.web.js",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules npx jest",
    "dev": "nodemon ./doc/Examples/demo-express.cjs",
    "nodew": "node --watch ./doc/Examples/demo-express.cjs",
    "deva": "setsid nohup nodemon ./doc/Examples/demo-express.cjs > nodeapp.log 2>&1 &",
    "start": "pm2 start ./doc/Examples/demo-express.cjs --name dolphin",
    "stop": "pm2 stop dolphin",
    "delete": "pm2 delete dolphin",
    "clean": "bash ./scripts/cleanup.sh",
    "ngrok": "ngrok http 3000 --url=robust-camel-exciting.ngrok-free.app",
    "live": "start https://robust-camel-exciting.ngrok-free.app",
    "web": "cd ./scripts/ && start server.bat",
    "traffic": "cd ./scripts/ && python traffic.py"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manthanwar/JS-SVG-Client.git"
  },
  "keywords": [
    "scalable vector graphics",
    "svg",
    "javascript",
    "js"
  ],
  "bugs": {
    "url": "https://github.com/manthanwar/JS-SVG-Client/issues"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "webpack": "^5.103.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "express": "^4.22.1",
    "express-handlebars": "^8.0.4",
    "multer": "^2.0.2",
    "pm2": "^6.0.14",
    "request-ip": "^3.3.0"
  }
}
